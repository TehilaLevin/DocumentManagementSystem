    {
      "name": "Documents API",
      "item": [
        {
          "name": "Create Document - User 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has document details (without content)', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('title');",
                  "    pm.expect(jsonData).to.have.property('path');",
                  "    pm.expect(jsonData).to.have.property('author');",
                  "    pm.expect(jsonData).to.not.have.property('content');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "user1"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"path\": \"/documents/user1\",\n  \"title\": \"User 1 Document\",\n  \"content\": \"User 1 content\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:5000/api/documents",
              "protocol": "http",
              "host": ["127.0.0.1"],
              "port": "5000",
              "path": ["api", "documents"]
            }
          }
        },
